# the-aios/site — environment variables
#
# Copy this file to `.env.local` for local development (gitignored).
# For production, set these in the Vercel project settings → Environment Variables.

# Google Analytics 4 Measurement ID.
# Public (visible in page source on every site using GA) — not a secret.
# Configured at https://analytics.google.com under Admin → Data Streams.
# Falls back to the literal in src/components/Analytics.tsx if unset, so the
# build works without env config — set this only if you want to override.
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-8EBR2LPQDZ
